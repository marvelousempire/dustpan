# ── Dustpan Docker environment ───────────────────────────────────────────────
# Copy this file to .env before running ./docker/go
# Never commit .env to git.

# ── Postgres ─────────────────────────────────────────────────────────────────
POSTGRES_USER=dustpan
POSTGRES_PASSWORD=changeme
POSTGRES_DB=dustpan

# ── Caddy ────────────────────────────────────────────────────────────────────
# Dev:        leave blank → defaults to `localhost` with self-signed cert
# Production: set to your domain → Caddy auto-fetches Let's Encrypt cert
CADDY_HOST=localhost

# ── AI key vault ─────────────────────────────────────────────────────────────
# Random secret used to encrypt stored API keys (AES-256-GCM).
# Generate a new one:  python3 -c "import secrets; print(secrets.token_hex(32))"
DUSTPAN_MASTER_KEY=replace_with_a_random_64_char_hex_string

# ── Ollama (optional — only needed with --profile ollama) ────────────────────
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2
